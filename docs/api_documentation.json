              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Review created successfully",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "statusCode": 201,
                  "message": "Review created successfully",
                  "data": {
                    "id": "review-123",
                    "rating": 5,
                    "comment": "Very good and fast service"
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Reviews"],
        "summary": "Get my reviews",
        "security": [{ "bearerAuth": [] }],

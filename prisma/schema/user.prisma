model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  role   Role
  status UserStatus @default(UNBAN)

  phone      String?
  address    String?
  profileImg String?

  technicianProfile TechnicianProfile?

  bookings Booking[] @relation("CustomerBookings")
  reviews  Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
